@startuml
skinparam style strictuml
skinparam maxMessageSize 200

actor "Nhan vien" as Staff
actor "Admin" as Admin
participant "StaffFeaturePanels.feedbackPanel\n(View)" as StaffView
participant "StaffFeatureController\n(Facade)" as StaffFacade
participant "StaffFeedbackController" as StaffController
participant "StaffService" as StaffService
participant "StaffFeedbackRepository" as StaffRepository
participant "JpaStaffDataStore" as StaffDataStore
participant "AdminFeaturePanels.feedbackManagementPanel\n(View)" as AdminView
participant "AdminController\n(Facade)" as AdminFacade
participant "FeedbackManagementController" as AdminController
participant "AdminService" as AdminService
participant "AdminFeedbackRepository" as AdminRepository
participant "JpaAdminDataStore" as AdminDataStore
database "MySQL\n(BoardingHouse_DB)" as DB

Note over Staff, DB: QUY TRINH GHI NHAN VA CAP NHAT SU CO

Staff -> StaffView : 1. Nhap noi dung su co
StaffView -> StaffFacade : 2. addFeedback(roomCode, title, description, priority)
activate StaffFacade
StaffFacade -> StaffController : 3. addFeedback(...)
activate StaffController
StaffController -> StaffService : 4. addFeedback(...)
activate StaffService
StaffService -> StaffRepository : 5. addFeedback(...)
activate StaffRepository
StaffRepository -> StaffDataStore : 6. addFeedback(...)
activate StaffDataStore
StaffDataStore -> DB : 7. INSERT PHAN_HOI (CHO_XU_LY)
activate DB
DB -->> StaffDataStore : 8. Success
StaffDataStore -->> StaffRepository : 9. FeedbackItem moi
StaffRepository -->> StaffService : 10. FeedbackItem moi
StaffService -->> StaffController : 11. FeedbackItem moi
StaffController -->> StaffFacade : 12. Da gui Admin
StaffFacade -->> StaffView : 13. Hien thong bao thanh cong
deactivate DB
deactivate StaffDataStore
deactivate StaffRepository
deactivate StaffService
deactivate StaffController
deactivate StaffFacade

Note over Admin, DB: Admin chi dao va cap nhat trang thai xu ly

Admin -> AdminView : 14. Chon su co va trang thai moi
AdminView -> AdminFacade : 15. updateFeedbackStatus(id, status)
activate AdminFacade
AdminFacade -> AdminController : 16. updateFeedbackStatus(id, status)
activate AdminController
AdminController -> AdminService : 17. updateFeedbackStatus(id, status)
activate AdminService
AdminService -> AdminRepository : 18. updateFeedbackStatus(id, status)
activate AdminRepository
AdminRepository -> AdminDataStore : 19. updateFeedbackStatus(id, status)
activate AdminDataStore
AdminDataStore -> DB : 20. UPDATE PHAN_HOI SET trang_thai = ?
DB -->> AdminDataStore : 21. Success
AdminDataStore -->> AdminRepository : 22. FeedbackItem da cap nhat
AdminRepository -->> AdminService : 23. FeedbackItem da cap nhat
AdminService -->> AdminController : 24. FeedbackItem da cap nhat
AdminController -->> AdminFacade : 25. Done
AdminFacade -->> AdminView : 26. Refresh list va hien message

deactivate AdminDataStore
deactivate AdminRepository
deactivate AdminService
deactivate AdminController
deactivate AdminFacade
@enduml
