@startuml
skinparam style strictuml
skinparam maxMessageSize 190

actor "Admin" as Admin
participant "AdminFeaturePanels.feedbackManagementPanel\n(View)" as View
participant "AdminController\n(Facade)" as Facade
participant "FeedbackManagementController" as Controller
participant "AdminService" as Service
participant "AdminFeedbackRepository" as Repository
participant "JpaAdminDataStore" as DataStore
database "MySQL\n(BoardingHouse_DB)" as DB

Note over Admin, DB: INCIDENT DIRECTION (ADMIN)

Admin -> View : 1. Mo man hinh quan ly phan hoi
View -> Facade : 2. getFeedbacksByStatus(status)
activate Facade
Facade -> Controller : 3. getFeedbacksByStatus(status)
activate Controller
Controller -> Service : 4. getFeedbacksByStatus(status)
activate Service
Service -> Repository : 5. getFeedbacksByStatus(status)
activate Repository
Repository -> DataStore : 6. getFeedbacksByStatus(status)
activate DataStore
DataStore -> DB : 7. SELECT PHAN_HOI theo trang_thai
activate DB
DB -->> DataStore : 8. incidentList
DataStore -->> Repository : 9. incidentList
Repository -->> Service : 10. incidentList
Service -->> Controller : 11. incidentList
Controller -->> Facade : 12. incidentList
Facade -->> View : 13. Render incident list

deactivate DB
deactivate DataStore
deactivate Repository
deactivate Service
deactivate Controller
deactivate Facade

Admin -> View : 14. Cap nhat trang thai (DANG_SUA/HOAN_THANH)
View -> Facade : 15. updateFeedbackStatus(incidentId, status)
activate Facade
Facade -> Controller : 16. updateFeedbackStatus(incidentId, status)
activate Controller
Controller -> Service : 17. updateFeedbackStatus(incidentId, status)
activate Service
Service -> Repository : 18. updateFeedbackStatus(incidentId, status)
activate Repository
Repository -> DataStore : 19. updateFeedbackStatus(incidentId, status)
activate DataStore
DataStore -> DB : 20. UPDATE PHAN_HOI SET trang_thai = ?
DB -->> DataStore : 21. Success
DataStore -->> Repository : 22. FeedbackItem da cap nhat
Repository -->> Service : 23. FeedbackItem da cap nhat
Service -->> Controller : 24. FeedbackItem da cap nhat
Controller -->> Facade : 25. Update success
Facade -->> View : 26. Refresh list + show message

deactivate DataStore
deactivate Repository
deactivate Service
deactivate Controller
deactivate Facade
@enduml
