@startuml
skinparam style strictuml
skinparam maxMessageSize 150

actor "Nhân viên" as Staff
participant "ContractPanel\n(View)" as View
participant "ContractController" as Controller
participant "ContractService" as Service
database "MySQL\n(BoardingHouse_DB)" as DB

Note over Staff, DB: QUY TRÌNH LẬP HỢP ĐỒNG VÀ NHẬN PHÒNG MỚI

Staff -> View : 1. Nhập thông tin khách & Chọn phòng
View -> Controller : 2. validateAndCheckRoom(roomId)
activate Controller

Controller -> Service : 3. isRoomAvailable(roomId)
activate Service
Service -> DB : 4. SELECT trang_thai FROM PHONG WHERE id = ?
activate DB
DB -->> Service : 5. Trả về 'TRONG'
deactivate DB
Service -->> Controller : 6. Room is available
deactivate Service
Controller -->> View : 7. Hiển thị: "Phòng sẵn sàng"
deactivate Controller

Staff -> View : 8. Nhập tiền cọc, ngày bắt đầu & Tải ảnh hợp đồng
View -> Controller : 9. createNewContract(customerDTO, contractDTO, vehicleDTO)
activate Controller

Controller -> Service : 10. processContractCreation(customerDTO, contractDTO, vehicleDTO)
activate Service

Service -> DB : 11. Begin Transaction
activate DB

' Lưu thông tin khách thuê trước để lấy ID
Service -> DB : 12. INSERT INTO KHACH_THUE (ho_ten, so_cccd, so_dien_thoai)
DB -->> Service : 13. Trả về customer_id

' Lưu hợp đồng sử dụng customer_id vừa lấy
Service -> DB : 14. INSERT INTO HOP_DONG (customer_id, room_id, tien_coc, ...)
DB -->> Service : 15. Trả về contract_id

' Lưu thông tin xe nếu khách có đăng ký
alt Khách có đăng ký gửi xe
    Service -> DB : 16. INSERT INTO XE (hop_dong_id, loai_xe, bien_so)
end

' Cập nhật trạng thái phòng sang Đã thuê
Service -> DB : 17. UPDATE PHONG SET trang_thai = 'DA_THUE' WHERE id = ?

Service -> DB : 18. Commit Transaction
DB -->> Service : 19. Success
deactivate DB

Service -->> Controller : 20. Contract created successfully
deactivate Service

Controller -->> View : 21. Show Success Message & Print Contract
deactivate Controller

View -->> Staff : 22. Thông báo hoàn tất & Bàn giao chìa khóa
@enduml