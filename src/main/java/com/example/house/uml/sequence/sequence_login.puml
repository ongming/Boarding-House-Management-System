@startuml
skinparam style strictuml
skinparam maxMessageSize 150

actor "Người dùng\n(Admin/Nhân viên)" as User
participant "Giao diện\nĐăng nhập" as UI
participant "Hệ thống\n(Máy chủ)" as Server
database "CSDL\n(Bảng TAI_KHOAN)" as DB

User -> UI : 1. Nhập ten_dang_nhap & mat_khau\nvà bấm Đăng nhập
activate UI

UI -> Server : 2. Gửi yêu cầu xác thực\n(ten_dang_nhap, mat_khau)
activate Server

Server -> DB : 3. Truy vấn tìm tài khoản\n(SELECT * FROM TAI_KHOAN\nWHERE ten_dang_nhap = ...)
activate DB
DB --> Server : 4. Trả về kết quả (thông tin tài khoản hoặc null)
deactivate DB

alt Tài khoản không tồn tại hoặc sai mật khẩu
    Server --> UI : 5a. Trả về thông báo lỗi
    UI --> User : 6a. Hiển thị "Sai tài khoản hoặc mật khẩu"
else Xác thực thành công
    Server -> Server : 5b. Tạo phiên làm việc (Session/Token)

    alt loai_tai_khoan == "ADMIN"
        Server --> UI : 6b. Trả về Token & Quyền Admin
        UI --> User : 7b. Chuyển hướng sang Trang Quản trị
    else loai_tai_khoan == "NHAN_VIEN"
        Server --> UI : 6c. Trả về Token & Quyền Nhân viên
        UI --> User : 7c. Chuyển hướng sang Trang Nhân viên
    end
end

deactivate Server
deactivate UI
@enduml