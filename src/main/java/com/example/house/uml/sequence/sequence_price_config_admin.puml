@startuml
skinparam style strictuml
skinparam maxMessageSize 150

actor "Admin" as Admin
participant "PricingConfigPanel\n(View)" as View
participant "PricingConfigController" as Controller
participant "PricingConfigService" as Service
database "MySQL\n(BoardingHouse_DB)" as DB

Note over Admin, DB: PRICE CONFIGURATION (ADMIN)

Admin -> View : 1. Open price config screen
View -> Controller : 2. loadCurrentRates()
activate Controller
Controller -> Service : 3. getCurrentRates()
activate Service
Service -> DB : 4. SELECT * FROM CAU_HINH_GIA
activate DB
DB -->> Service : 5. rateList
Deactivate DB
Service -->> Controller : 6. rateList
Deactivate Service
Controller -->> View : 7. Render current rates
Deactivate Controller

Admin -> View : 8. Edit rates and click Save
View -> Controller : 9. updateRates(rateList)
activate Controller
Controller -> Service : 10. validateAndSaveRates(rateList)
activate Service

Service -> Service : 11. Validate rate >= 0 and type in {DIEN, NUOC, RAC, XE}
alt Invalid input
    Service -->> Controller : 12. Validation error
else Valid input
    Service -> DB : 13. Begin Transaction
    activate DB
    loop Each rate
        Service -> DB : 14. INSERT or UPDATE CAU_HINH_GIA
    end
    Service -> DB : 15. Commit
    DB -->> Service : 16. Success
    deactivate DB
    Service -->> Controller : 17. Save success
end

Deactivate Service
Controller -->> View : 18. Show result message
Deactivate Controller
@enduml
