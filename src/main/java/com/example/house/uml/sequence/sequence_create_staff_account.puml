@startuml
skinparam style strictuml
skinparam maxMessageSize 150

actor "Quản trị viên" as Admin
participant "Giao diện\nQuản lý" as UI
participant "Hệ thống\n(Server/Backend)" as Server
database "Bảng\nTAI_KHOAN" as DB_TK
database "Bảng\nNHAN_VIEN" as DB_NV

Admin -> UI : 1. Nhập thông tin nhân viên mới\n(ten_dang_nhap, mat_khau, ho_ten)
activate UI

UI -> Server : 2. Gửi dữ liệu tạo tài khoản
activate Server

' Bước 1: Kiểm tra ràng buộc UNIQUE
Server -> DB_TK : 3. Kiểm tra tên đăng nhập\n(SELECT id FROM TAI_KHOAN\nWHERE ten_dang_nhap = ...)
activate DB_TK
DB_TK --> Server : 4. Trả về kết quả (Có/Không tồn tại)
deactivate DB_TK

alt Tên đăng nhập đã tồn tại
    Server --> UI : 5a. Báo lỗi "Tên đăng nhập đã được sử dụng"
    UI --> Admin : 6a. Hiển thị thông báo lỗi yêu cầu nhập lại
else Tên đăng nhập hợp lệ
    ' Bước 2: Xử lý bảo mật và lưu trữ
    Server -> Server : 5b. Mã hóa mật khẩu (ví dụ: BCrypt)
    Server -> Server : 6b. Bắt đầu Database Transaction

    ' Lưu bảng gốc
    Server -> DB_TK : 7. Thêm mới tài khoản\n(INSERT INTO TAI_KHOAN (ten_dang_nhap,\nmat_khau, ho_ten, loai_tai_khoan = 'NHAN_VIEN'))
    activate DB_TK
    DB_TK --> Server : 8. Trả về id (tai_khoan_id) vừa tạo
    deactivate DB_TK

    ' Lưu bảng con (quan hệ 1-1)
    Server -> DB_NV : 9. Thêm mới nhân viên\n(INSERT INTO NHAN_VIEN (tai_khoan_id,\nca_lam_viec = NULL))
    activate DB_NV
    DB_NV --> Server : 10. Xác nhận lưu thành công
    deactivate DB_NV

    Server -> Server : 11. Commit Transaction hoàn tất

    Server --> UI : 12. Trả về thông báo thành công
    UI --> Admin : 13. Hiển thị "Đã cấp tài khoản thành công"\nvà làm mới danh sách nhân sự
end

deactivate Server
deactivate UI
@enduml