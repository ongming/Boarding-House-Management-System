@startuml
skinparam style strictuml

|Nhân viên|
start
:Chọn tháng và năm cần tính tiền;
:Nhấn lệnh "Tính toán hóa đơn đồng loạt";

|Hệ thống|
:Lấy danh sách các hợp đồng đang có hiệu lực
(từ bảng HOP_DONG);

repeat
  :Đọc dữ liệu phòng tương ứng (bảng PHONG);
  :Lấy chỉ số điện nước đã chốt trong tháng
  (từ bảng CHI_SO_DIEN_NUOC);
  :Lấy các đơn giá dịch vụ hiện hành
  (từ bảng CAU_HINH_GIA);

  fork
    :Tính tien_phong (lấy gia_thue_co_ban);
  fork again
    :Tính tien_dien và tien_nuoc
    ((Số mới - Số cũ) * đơn giá);
  fork again
    :Đếm số lượng xe (từ bảng XE)
    => Tính tien_xe;
  fork again
    :Lấy số lượng người ở
    => Tính tien_rac và các phí khác;
  end fork

  :Cộng tổng các khoản thành tong_tien;
  :Tạo bản ghi mới vào bảng HOA_DON
  (mặc định da_thanh_toan = false);

repeat while (Còn hợp đồng chưa tính?) is (Có)
-> Không;

:Tổng hợp danh sách hóa đơn vừa tạo;
:Hiển thị danh sách lên màn hình;

|Nhân viên|
:Kiểm tra rà soát lại các con số;
:Chọn "Xuất file" hoặc "Gửi thông báo" cho khách thuê;
stop
@enduml