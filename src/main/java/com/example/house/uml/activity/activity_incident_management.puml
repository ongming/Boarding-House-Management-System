@startuml
skinparam style strictuml

|Nhân viên|
start
:Tiếp nhận phản ánh từ khách thuê;
:Mở chức năng "Ghi nhận sự cố";
:Chọn phòng và nhập nội dung chi tiết;

|Hệ thống|
:Tự động lấy **nhan_vien_id** từ phiên đăng nhập;
:Tạo bản ghi mới vào bảng **PHAN_HOI**;
:(Trạng thái: 'CHO_XU_LY');

|Admin|
:Xem danh sách sự cố 'CHO_XU_LY';
:Đánh giá và chỉ đạo phân công thợ;
:Cập nhật trạng thái thành 'DANG_SUA';

|Hệ thống|
:Lưu thay đổi vào DB;
:Gửi thông báo cập nhật cho Nhân viên;

|Nhân viên|
:Phối hợp sửa chữa thực tế;
:Xác nhận hoàn tất trên phần mềm;

|Hệ thống|
:Cập nhật trạng thái thành 'HOAN_THANH';
:Lưu thời gian hoàn thành;

|Nhân viên|
:Thông báo cho khách thuê;
stop
@enduml