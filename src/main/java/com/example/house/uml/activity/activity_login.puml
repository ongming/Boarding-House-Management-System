@startuml
skinparam style strictuml

|Người dùng|
start
repeat
  :Mở màn hình đăng nhập;
  :Nhập tên đăng nhập và mật khẩu;
  :Nhấn nút "Đăng nhập";

  |Hệ thống|
  :Tìm tài khoản theo tên đăng nhập;
  :Đối chiếu mật khẩu;
  backward: Hiển thị lỗi "Sai tài khoản hoặc mật khẩu";
repeat while (Thông tin hợp lệ?) is (Không)

-> Có;
:Kiểm tra loại tài khoản;

if (Vai trò?) then (ADMIN)
  :Chuyển sang màn hình quản trị;
else (NHÂN_VIÊN)
  :Chuyển sang màn hình nhân viên;
endif

|Người dùng|
:Bắt đầu sử dụng hệ thống;
stop
@enduml
