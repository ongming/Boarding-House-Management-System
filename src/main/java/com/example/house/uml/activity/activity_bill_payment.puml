@startuml
skinparam style strictuml

|Nhân viên|
start
:Tìm và chọn hóa đơn cần thu;

if (Hóa đơn đã thanh toán?) then (Có)
  :Thông báo "Hóa đơn đã hoàn tất";
  stop
else (Không)
endif

:Chọn hình thức thanh toán;

if (Hình thức?) then (Chuyển khoản)
  :Yêu cầu khách chuyển khoản;
  :Xác nhận đã nhận tiền;
else (Tiền mặt)
  :Thu tiền mặt từ khách;
endif

|Hệ thống|
:Cập nhật trạng thái đã thanh toán;
:Lưu hình thức thanh toán;
:Ghi nhận ngày thanh toán;

|Nhân viên|
:Thông báo thu tiền thành công;
:In biên nhận cho khách;
stop
@enduml
