<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="boarding-house-pu" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>com.example.house.model.entity.Account</class>
        <class>com.example.house.model.entity.Employee</class>
        <class>com.example.house.model.entity.Room</class>
        <class>com.example.house.model.entity.Tenant</class>
        <class>com.example.house.model.entity.Contract</class>
        <class>com.example.house.model.entity.Vehicle</class>
        <class>com.example.house.model.entity.UtilityReading</class>
        <class>com.example.house.model.entity.Invoice</class>
        <class>com.example.house.model.entity.Compensation</class>
        <class>com.example.house.model.entity.Feedback</class>
        <class>com.example.house.model.entity.RateConfig</class>
        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/BoardingHouse_Pro?useSSL=false&amp;serverTimezone=Asia/Ho_Chi_Minh&amp;allowPublicKeyRetrieval=true"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="123456"/>
            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
        </properties>
    </persistence-unit>
</persistence>
